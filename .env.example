# Replit Secrets / environment variables used by the imported S-Movie workspace.
# Keep real values in Replit Secrets; do not commit a populated .env file.

# Required by the mobile AI features. The Expo workflow maps this to
# EXPO_PUBLIC_GEMINI_API_KEY at runtime.
GEMINI_API_KEY=

# The API and mobile app may also use these project-provided values.
TMDB_API_KEY=
YOUTUBE_API_KEY=